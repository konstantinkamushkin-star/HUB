# Copy to `.env` and adjust. NestJS reads these via @nestjs/config.
#
# Запуск: из этой папки выполните `npm run start:dev` и оставьте процесс работать.
# Проверка: в браузере откройте http://localhost:3000/api/health (должен быть JSON со status healthy).
#
# Чеклист до аренды сервера: docs/PRODUCTION_PREP.md

NODE_ENV=development
PORT=3000

# Security / Auth
# Production: сгенерировать секрет (не коммитить): openssl rand -base64 48
JWT_SECRET=change-me-in-production

# Sign in with Apple / Google (проверка id_token на сервере)
# Apple: audience = Bundle ID приложения (например Dive-Hub.ru). Несколько значений — через запятую.
# APPLE_CLIENT_ID=Dive-Hub.ru
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# Несколько клиентов (iOS + Android): GOOGLE_CLIENT_IDS=id1.apps.googleusercontent.com,id2.apps.googleusercontent.com

# CORS
# Development: один origin или список через запятую.
# Production: ОБЯЗАТЕЛЬНО явный список (иначе приложение не стартует при NODE_ENV=production):
# CORS_ORIGINS=https://admin.example.com,https://app.example.com
# Поддомен API (https://api...) в CORS не нужен — в CORS попадают origin’ы браузерных приложений, не URL API.
CORS_ORIGINS=http://localhost:3001

# За reverse proxy / load balancer: доверять X-Forwarded-* (см. Express trust proxy).
# Примеры: 1 (один хоп), 2, true
# TRUST_PROXY=1

# Validation hardening:
# В production по умолчанию true (400 на лишние поля DTO),
# в development по умолчанию false для обратной совместимости.
# FORBID_NON_WHITELISTED=true

# Глобальный rate limit (мс): макс. запросов с одного IP за окно. GET /api/health исключён.
# Production: подстройте под нагрузку и CDN (типично 60000 мс и лимит 60–300).
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=divehub

# Redis cache (в production используйте реальный Redis, не полагайтесь на in-memory fallback)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# SMTP (опционально: сброс пароля и др. — см. mail.service)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# Python ONNX-сервис: `cd ai-service && ./start.sh` (по умолчанию порт 8010, см. PORT в start.sh).
# Либо одной командой: `./start-neural-test-stack.sh` из папки backend.
AI_UNDERWATER_SERVICE_URL=http://127.0.0.1:8010

# Перевод POST /api/translate: самостоятельный LibreTranslate (HTTP), без Google.
# Поднять: из backend — `docker compose --profile translate up -d libretranslate`, затем:
# LIBRETRANSLATE_URL=http://127.0.0.1:5000
# LIBRETRANSLATE_API_KEY=
# Опциональный fallback, если Libre недоступен:
# GOOGLE_TRANSLATE_API_KEY=

# Куда Nest проксирует POST /api/v1/process/photo/{engine} (кнопки Cursor / «Автоматическая коррекция 2» Sea-Thru).
# Должен быть либо **underwater-vision-module** (uvicorn uvm.api.app), либо **актуальный** ai-service из этого репо
# (с `seathru` в main.py + scipy). Старая сборка ai-service отвечает 400 «only cursor».
# UVM_URL=http://127.0.0.1:8010
# Таймаут HTTP от Nest к Python (мс). JMSE на 2K >60 с; по умолчанию 300000 (5 мин).
# AI_UNDERWATER_HTTP_TIMEOUT_MS=300000

# SeaSplat runtime (в underwater-vision-module):
# Рабочая папка сцен/job (если не задано: /tmp/uvm-seasplat)
# UVM_SEASPLAT_WORKDIR=/tmp/uvm-seasplat
# Путь к внешнему runner-скрипту/бинарнику SeaSplat (если пусто — fallback pipeline)
# UVM_SEASPLAT_RUNNER=/absolute/path/to/seasplat_runner.sh
# Таймаут runner (сек)
# UVM_SEASPLAT_TIMEOUT_S=900

# Импорт поездок с сайта (POST /api/admin/trips/import/*): HTML → OpenAI → запись в trips + скачивание фото в /uploads/media.
# OPENAI_API_KEY=sk-...
# OPENAI_TRIP_IMPORT_MODEL=gpt-4o-mini
