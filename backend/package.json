{
  "name": "divehub-backend",
  "version": "1.0.0",
  "description": "DiveHub Backend API with optimized geo search",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "verify:prod-build": "nest build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate",
    "migration:run": "typeorm-ts-node-commonjs migration:run",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert",
    "migrate:all": "node scripts/apply-all-migrations.cjs",
    "mail:smoke": "node scripts/smtp-smoke.cjs",
    "migrate:001-dive-sites": "node scripts/apply-migration-001-dive-sites.cjs",
    "migrate:friendships": "node scripts/apply-friendships-migration.cjs",
    "migrate:008": "node scripts/apply-migration-008.cjs",
    "migrate:chat": "node scripts/apply-chat-migrations.cjs",
    "migrate:feed": "node scripts/apply-feed-migration.cjs",
    "migrate:dive-logs": "node scripts/apply-dive-logs-migration.cjs",
    "migrate:reviews": "node scripts/apply-reviews-migration.cjs",
    "migrate:admin-foundation": "node scripts/apply-admin-foundation-migration.cjs",
    "migrate:reports-moderation": "node scripts/apply-reports-moderation-migration.cjs",
    "migrate:settings-flags-notifications": "node scripts/apply-settings-flags-notifications-migration.cjs",
    "migrate:compliance-search-data-jobs": "node scripts/apply-compliance-search-data-jobs-migration.cjs",
    "migrate:merge-verification": "node scripts/apply-merge-verification-migration.cjs",
    "migrate:admin-tz-extensions": "node scripts/apply-admin-tz-extensions-migration.cjs",
    "migrate:admin-totp-analytics": "node scripts/apply-admin-totp-analytics-migration.cjs",
    "migrate:user-must-change-password": "node scripts/apply-user-must-change-password-migration.cjs",
    "create:super-admin": "node scripts/create-super-admin.cjs",
    "db:counts": "node scripts/db-show-counts.cjs",
    "seed:dive-sites": "node import_processed_dive_sites.js dive_sites_data.json",
    "import:opendivemap": "node scripts/import_opendivemap_geojson.js",
    "migrate:from-prisma": "node scripts/migrate-from-prisma-divehub.cjs"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^2.1.1",
    "@nestjs/common": "^10.2.10",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.10",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.2.10",
    "@nestjs/platform-ws": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^5.2.4",
    "cache-manager-redis-yet": "^5.0.1",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "nodemailer": "^6.9.16",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@types/express": "^4.17.21",
    "@types/geojson": "^7946.0.16",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.17",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
