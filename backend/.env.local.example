# Скопируйте в .env.local и вставьте ключ из RapidAPI → приложение → default-application / Code snippets.
# Файл .env.local в git не коммитится (см. backend/.gitignore).

RAPIDAPI_KEY=
RAPIDAPI_HOST=world-scuba-diving-sites-api.p.rapidapi.com
# Как в RapidAPI → Code Snippets (если 404 — попробуйте /divesites/gps)
RAPIDAPI_GPS_PATH=/divesites/gs

# Stripe (optional): enables `POST /api/bookings/payment-intent` for online / Google Pay deposits.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
