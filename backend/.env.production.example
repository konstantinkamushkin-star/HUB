# Production для dive-hub.ru + docker compose (postgres/redis в той же сети compose).
#
# На сервере: скопируйте в `.env` в каталоге backend и ОБЯЗАТЕЛЬНО замените JWT_SECRET:
#   cp .env.production.example .env
#   openssl rand -base64 48   # вставьте вывод в JWT_SECRET=
#
# Не коммитьте файл `.env` с реальными секретами.

NODE_ENV=production
PORT=3000

# Внешний порт хоста → контейнер api:3000. Если «Bind for 0.0.0.0:3000 failed» — задать свободный порт
# (например 3001) и в nginx для api.dive-hub.ru указать proxy_pass http://127.0.0.1:этот_порт
# С интернета достаточно 443 у reverse proxy; 152-ФЗ/белый список портов не мешает localhost→API.
# API_PUBLISH_PORT=3001

# Внешний порт хоста → контейнер postgres:5432 (если на хосте уже слушает другой Postgres).
# POSTGRES_PUBLISH_PORT=5433

# Compose: один пароль для контейнера postgres и для API (DB_PASSWORD). Иначе импорт с хоста ок, логин — HTTP 500.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=divehub

# Сгенерируйте: openssl rand -base64 48
JWT_SECRET=REPLACE_ME_RUN_openssl_rand_base64_48

# OAuth (iOS / Android id_token): audience = Bundle ID или Google iOS client id (*.apps.googleusercontent.com)
# APPLE_CLIENT_ID=Dive-Hub.ru
# GOOGLE_CLIENT_ID=

# Браузерные приложения (не URL API). Добавьте https://admin.dive-hub.ru когда появится админка.
CORS_ORIGINS=https://dive-hub.ru,https://www.dive-hub.ru

# Nginx/Caddy перед API
TRUST_PROXY=1

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Имена сервисов из docker-compose.yml
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=divehub

REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=

# SMTP (раскомментируйте и заполните при необходимости)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@dive-hub.ru

# AI/UVM на этом сервере не подняты — закомментировано, иначе health/прокси могут ждать недоступный сервис
# AI_UNDERWATER_SERVICE_URL=http://127.0.0.1:8010
# UVM_URL=http://127.0.0.1:8010
# Таймаут Nest→UVM для POST /api/v1/process/video/* (мс). Для роликов ~5 мин рекомендуется 45–60 мин.
# UVM_VIDEO_PROXY_TIMEOUT_MS=3600000

# OPENAI_API_KEY=
# OPENAI_TRIP_IMPORT_MODEL=gpt-4o-mini
