    <string name="help_intro">Here is a quick guide to the main areas of the app. For account or billing issues, use the website or contact support.</string>
    <string name="help_partner_application_button">Open partner application</string>
    <string name="help_section_account_body">Change your password from Profile or Settings. Sign out from Profile. Partner roles can open the API site in a browser for full admin tools.</string>
    <string name="help_section_account_title">Account</string>
    <string name="help_section_explore_body">Browse dive sites, centers, and shops. Switch between list and map, use filters, and open a place to read details and reviews.</string>
    <string name="help_section_explore_title">Explore</string>
    <string name="help_section_logbook_body">Log your dives with depth, time, and photos. Your entries power statistics and achievements in your profile.</string>
    <string name="help_section_logbook_title">Logbook</string>
    <string name="help_section_partners_body">Run a dive center or retail shop? Submit a public application for verification. You can do this without logging in; use the same form from the login screen.</string>
    <string name="help_section_partners_title">Dive centers &amp; shops</string>
    <string name="help_section_trips_body">Open Trips from your profile or the More menu to browse scheduled group trips and open a trip for details.</string>
    <string name="help_section_trips_title">Trips</string>
    <string name="hub_achievements_body">Achievements and badges will appear here as you log dives and explore sites.</string>
    <string name="hub_help_body">Help and FAQ will appear here. Contact support through the website if you need urgent assistance.</string>
    <string name="hub_notifications_body">No notifications yet. Trip updates and friend activity will show here when available.</string>
    <string name="hub_settings_body">App preferences and account options. More controls are coming in a future update.</string>
    <string name="hub_statistics_body">Your dive statistics will be summarized here once we connect this screen to your logbook data.</string>
